worker_processes 1;
error_log PROXY_RUN_DIR/error.log;
pid PROXY_RUN_DIR/nginx.pid;

events {
    worker_connections 64;
}

http {
    access_log PROXY_RUN_DIR/access.log;

    server {
        listen 127.0.0.1:4000;

        location / {
            proxy_pass https://aiapi-prod.stanford.edu;
            proxy_ssl_server_name on;
            proxy_set_header Host aiapi-prod.stanford.edu;
            proxy_set_header Authorization "Bearer PROXY_API_KEY";
            proxy_set_header Connection '';
            proxy_http_version 1.1;
            proxy_buffering off;
            chunked_transfer_encoding on;
        }
    }
}
